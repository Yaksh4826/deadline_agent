# Groq API - used by agent.py for the main CrewAI agent (Llama model)
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API - used by tools.py for plan_daily_tasks (Gemini model)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Centennial Luminate calendar feed (.ics URL)
ICS_URL=https://your-luminate-calendar-feed.ics

# Twilio - for WhatsApp delivery
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
YOUR_WHATSAPP_TO=whatsapp:+1234567890
